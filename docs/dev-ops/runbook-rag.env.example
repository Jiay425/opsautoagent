# Copy this file to docs/dev-ops/runbook-rag.local.env and fill the two API keys.
# The *.local.env file is ignored by git.

OPENAI_BASE_URL=https://api.pie-xian.com
OPENAI_EMBEDDING_MODEL=qwen3-embedding-8b
OPENAI_EMBEDDING_DIMENSIONS=768

OPS_RUNBOOK_EMBEDDING_BASE_URL=https://api.pie-xian.com
OPS_RUNBOOK_EMBEDDING_MODEL=qwen3-embedding-8b
OPS_RUNBOOK_EMBEDDING_DIMENSIONS=768

OPS_RUNBOOK_RERANK_ENABLED=true
OPS_RUNBOOK_RERANK_ENDPOINT=https://api.pie-xian.com/v1/rerank
OPS_RUNBOOK_RERANK_MODEL=qwen3-reranker-8b
OPS_RUNBOOK_RERANK_CANDIDATE_TOP_N=20
OPS_RUNBOOK_RERANK_TIMEOUT_MS=30000

# Required local secrets:
OPENAI_API_KEY=
OPS_RUNBOOK_EMBEDDING_API_KEY=
OPS_RUNBOOK_RERANK_API_KEY=

# Usually keep false. The app now checks PGVector dimensions automatically.
OPS_RUNBOOK_VECTOR_REBUILD_ON_STARTUP=false
OPS_RUNBOOK_VECTOR_SCHEMA_CHECK_ON_STARTUP=true
